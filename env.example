# ── Telegram ──────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# ── Database ──────────────────────────────────
DATABASE_PATH=otp_bot.db

# ── Active Provider ───────────────────────────
ACTIVE_PROVIDER=smsman

# ── SMS Providers API Keys ────────────────────
SMSHUB_API_KEY=
FIVESIM_API_KEY=
SMSACTIVATE_API_KEY=
GRIZZLYSMS_API_KEY=
VAKSMS_API_KEY=
ONLINESIM_API_KEY=
SMSMAN_API_KEY=your_smsman_key_here

# ── Business Logic ────────────────────────────
PROFIT_MARGIN=20
OTP_TIMEOUT=300
REFUND_ENABLED=true

# ── Localization ──────────────────────────────
DEFAULT_LANG=ar

# ── Crypto Payment (BEP20 / TRC20) ───────────
# يمكن ضبط هذه الإعدادات من لوحة الأدمن مباشرة
# BEP20_ADDRESS=0xYourWalletAddressHere
# TRC20_ADDRESS=TYourTronWalletAddressHere
# TRONGRID_API_KEY=your_trongrid_key_here
