# ════════════════════════════════════════════════
#  OTP Bot — ملف الإعدادات
#  انسخ هذا الملف واحفظه بـ اسم  .env
# ════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────
BOT_TOKEN=ضع_توكن_البوت_هنا
ADMIN_IDS=123456789,987654321        # أرقام ID الأدمن مفصولة بفاصلة

# ── Database ──────────────────────────────────
DATABASE_PATH=otp_bot.db             # مسار ملف قاعدة البيانات

# ── DurianRCS API ─────────────────────────────
DURIAN_NAME=اسم_المستخدم_في_Durian
DURIAN_API_KEY=مفتاح_API_هنا

# ── Product IDs (PIDs) ────────────────────────
PID_TELEGRAM=0257                    # PID خاص بـ Telegram
PID_WHATSAPP_S1=0107                 # PID خاص بـ WhatsApp Server 1
PID_WHATSAPP_S2=0528                 # PID خاص بـ WhatsApp Server 2

# ── أسعار أولية (تُعدَّل لاحقاً من لوحة الأدمن) ─
PRICE_TG=0.25
PRICE_WA_S1=0.35
PRICE_WA_S2=0.40

# ── توقيتات ────────────────────────────────────
OTP_TIMEOUT=300                      # وقت انتظار الكود بالثواني (5 دقائق)
CANCEL_DELAY=60                      # ثواني قبل ظهور زر الإلغاء
REFUND_ENABLED=true                  # استرداد الرصيد عند الإلغاء/انتهاء الوقت

# ── قناة الإشعارات (اختياري) ──────────────────
NOTIF_CHANNEL_ID=                    # مثال: -1001234567890 أو @mychannel
NOTIF_CHANNEL_LINK=                  # مثال: https://t.me/mychannel

# ── اللغة الافتراضية ───────────────────────────
DEFAULT_LANG=ar                      # ar | en | fa

# ── الدفع بالكريبتو (يُعدَّل من لوحة الأدمن) ──
# BEP20_ADDRESS=0xعنوان_محفظتك
# TRC20_ADDRESS=Tعنوان_محفظتك_تون
# TRONGRID_API_KEY=مفتاح_TronGrid
